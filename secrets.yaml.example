device_name: "esp32-OT-MQTT-sensor"
mqtt_broker_address: "192.168.1.100"  # literal IPv4 or IPv6 address, no DNS names
# MQTT is plaintext (mqtt://) by default — Thread already encrypts every RF hop
# (AES-128-CCM), so for a LAN-only broker only the wired OTBR→broker hop is cleartext.
# See README "MQTT transport" for when to enable mqtt_tls below instead (e.g. a
# broker reached over the public internet).
mqtt_port: "1883"
mqtt_username: "Alice"
mqtt_password: "good_password_should_be_long"

# Enable MQTT-over-TLS (mqtts://) instead of plaintext (mqtt://). Default: "false"
# (unchanged behavior). When "true", reuses mqtt_port above for the TLS listener —
# update mqtt_port to your broker's TLS port when flipping this on (e.g. 8883, or
# your reverse-proxy's TLS port). Certificate verification uses the ESP-IDF public
# CA bundle by default (or mqtt_tls_ca_cert below, if set), with CN/hostname
# checking skipped — see README "MQTT transport" for why.
mqtt_tls: "false"

# Optional: base64 body (no "-----BEGIN/END-----" markers, no embedded newlines) of
# a self-signed or private CA / leaf certificate to pin instead of the public CA
# bundle. Leave empty ("") to use the public bundle (the default). Only consulted
# when mqtt_tls is "true".
mqtt_tls_ca_cert: ""

# Which network stack this device uses. "thread" (default) or "wifi".
transport: "thread"

# Required when transport is "thread"; ignored otherwise.
ot_tlv: "39328972098307___very_big_and_ugly_string_from_your_OpenThread_Border_Router___23762837460003232002"

# Required when transport is "wifi"; ignored otherwise. WPA2 STA credentials.
wifi_ssid: "MyHomeNetwork"
wifi_password: "correct horse battery staple"

# Which single IP family the Wi-Fi STA brings up: "ipv4" (default, DHCP) or "ipv6" (SLAAC).
# The other family is not brought up at all, and this MUST match mqtt_broker_address's own
# family above (the device only ever holds one family's address, so it can only reach a
# broker of that same family) — a mismatch is a fatal boot error, not a silent failure.
wifi_address_family: "ipv4"

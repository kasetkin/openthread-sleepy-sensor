#
# mbedTLS
#
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECJPAKE=y
CONFIG_MBEDTLS_ECJPAKE_C=y
# end of mbedTLS

#
# OpenThread
#
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_OPENTHREAD_BORDER_ROUTER=n
CONFIG_OPENTHREAD_MTD=y
CONFIG_OPENTHREAD_DNS64_CLIENT=y
CONFIG_OPENTHREAD_CLI=y
CONFIG_OPENTHREAD_TASK_SIZE=4096
CONFIG_OPENTHREAD_CONSOLE_ENABLE=n
# end of OpenThread

#
# lwIP
#
CONFIG_LWIP_TCPIP_TASK_STACK_SIZE=4096
CONFIG_LWIP_IPV6_NUM_ADDRESSES=8
# IPV4 + ND6 on for Wi-Fi (direct IPv4 connect; ND6/RA needed for SLAAC). Thread's netif
# doesn't use either (it's IPv6-only via NAT64, and does neighbor/route discovery at its
# own MLE layer via esp_openthread_netif_glue, bypassing lwIP's ND6 state machine) but
# there's one shared sdkconfig for the whole image, so both builds link this in.
CONFIG_LWIP_IPV4=y
CONFIG_LWIP_ND6=y
# SLAAC (RFC 4862) global/ULA address generation on the Wi-Fi STA netif, for
# wifi_address_family: "ipv6". Needs CONFIG_LWIP_ND6=y above to process Router Advertisements.
CONFIG_LWIP_IPV6_AUTOCONFIG=y
# end of lwIP

#
# IEEE 802.15.4
#
CONFIG_IEEE802154_ENABLED=y
# end of IEEE 802.15.4

#
# light sleep
#
CONFIG_PM_ENABLE=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
CONFIG_PM_POWER_DOWN_PERIPHERAL_IN_LIGHT_SLEEP=y
CONFIG_IEEE802154_SLEEP_ENABLE=y
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_SLEEP_POWER_DOWN_FLASH=y
CONFIG_ESP_MODEM_CLOCK_ENABLE_CHECKING=y
# end of light sleep

#
# Sleep Config (ESP32-C6)
#
CONFIG_ESP_PHY_MAC_BB_PD=y
# end of Sleep Config

#
# ESP System Settings
#
CONFIG_ESP_MAIN_TASK_STACK_SIZE=6144
# end of ESP System Settings

#
# Compiler
#
CONFIG_COMPILER_OPTIMIZATION_PERF=y
# end of Compiler

#
# Flash & Partition Table
# C6FH4 has 4 MB flash; the default 1 MB single-app partition can't hold the
# std::format-using firmware (~1.33 MB), so use a 2 MB factory app (partitions.csv).
#
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
# end of Flash & Partition Table

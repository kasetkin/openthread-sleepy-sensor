{
  "name": "ESP32 Sensor SD Logger",
  "image": "espressif/idf:v6.0.1",
  "runArgs": [
    "--device=/dev/ttyACM0",
    "--group-add=dialout"
  ],
  "remoteEnv": {
    "IDF_PATH": "/opt/esp/idf",
    "IDF_TOOLS_PATH": "/opt/esp",
    "BASH_ENV": "/usr/local/bin/idf-env.sh",
    // Keep Claude's global config (.claude.json) inside the bind-mounted
    // .claude dir so chat history / config survives a container rebuild.
    "CLAUDE_CONFIG_DIR": "/root/.claude"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "mounts": [
    "source=${localWorkspaceFolder}/.claude,target=/root/.claude,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "espressif.esp-idf-extension",
        "ms-vscode.cpptools",
        "anthropic.claude-code"
      ],
      "settings": {
        "idf.espIdfPath": "/opt/esp/idf",
        "idf.toolsPath": "/opt/esp"
      }
    }
  }
}
